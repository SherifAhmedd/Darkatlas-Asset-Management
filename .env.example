# App Configuration
PROJECT_NAME="DarkAtlas Asset Management API"
SECRET_KEY="replace-this-with-a-very-secure-random-secret-key-for-production"
ACCESS_TOKEN_EXPIRE_MINUTES=60
RATE_LIMIT_PER_MINUTE=60

# Database Settings
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=darkatlas_assets

# AI / LangChain Settings
# The system supports both OpenAI and mock mode (if keys are absent, for easy local testing)
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4o-mini
